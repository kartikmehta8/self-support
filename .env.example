NODE_ENV=development
LOG_LEVEL=info
PORT=4111

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-5.4

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_SUPPORT_CHANNEL_ID=
DISCORD_ADMIN_ROLE_IDS=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_SUPPORT_CHANNEL_ID=

# Persistence and queueing
SQLITE_PATH=./data/self-helper.sqlite
MASTRA_SQLITE_PATH=./data/mastra.sqlite
QUEUE_BACKEND=memory
REDIS_URL=redis://127.0.0.1:6379
ANSWER_CONCURRENCY=10

# Knowledge sources
SELF_REPO_URL=https://github.com/selfxyz/self.git
SELF_DOCS_REPO_URL=https://github.com/selfxyz/self-docs.git
REPO_BASE_PATH=./repos
REPO_REFRESH_CRON_MS=900000
MAX_SEARCH_RESULTS=8
