{
  "name": "self-helper-bot-poc",
  "version": "0.1.0",
  "description": "Discord and Slack support automation for Self Labs powered by Mastra.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/**/*.test.ts",
    "coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-exclude='src/index.ts' --test-coverage-exclude='src/integrations/discord/register-commands.ts' --test-coverage-exclude='src/mastra/index.ts' --test-coverage-exclude='src/mastra/agents/support-agent.ts' --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=90 test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p test/tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run typecheck && npm run typecheck:test && npm run lint && npm run format:check && npm run coverage",
    "register:discord": "tsx src/integrations/discord/register-commands.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.31.0",
    "@mastra/libsql": "^1.9.1",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.17.4",
    "@slack/web-api": "^7.8.0",
    "@hono/node-server": "^2.0.1",
    "better-sqlite3": "^11.9.1",
    "bullmq": "^5.34.0",
    "discord.js": "^14.19.3",
    "dotenv": "^17.4.2",
    "hono": "^4.7.5",
    "ioredis": "^5.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.59.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
